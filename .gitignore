# Python
__pycache__/
*.py[cod]
*.egg-info/

# ML artifacts — kept in repo for now, but ignore regenerated intermediates
*.ids
data/tokenized/
data/remi_txt/

# Large MIDI latents (1.8GB, exceeds git size limit; reproduce with:
#   python -m samar.precompute_midi_latents)
latents/midi_latents.pt

# TensorBoard
logs/*.tfevents.*
# Keep hparams.yaml
!logs/**/*.yaml

# Backup vocab pickles (kept locally for recovery, not needed in repo)
samar/samar_vocab_v*_backup.pkl

# Test outputs (regenerated by running tests)
samar/tests/data/reconstructed.xml
samar/tests/data/1re.xml
samar/tests/data/desert_echoes_structured.xml

# Inference outputs (regenerated by generating.py)
generated.xml
generated_events.txt

# MuseScore auto-save directories
.mscbackup/

# Editors
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Local backups (preserved on disk for rollback, not tracked in repo)
backups/

# Trained Arabic transformer weights — TRACKED so fresh clones can reproduce.
# Regenerate with: python -m samar.train_samar_transformer --num-epochs 30
# (~20-30 min/epoch on CPU, ~10h for 30 epochs)
# checkpoints/samar_transformer.pt       (last epoch, full state for resume)
# checkpoints/samar_transformer_best.pt (best val_loss across epochs)
